# Public app
NEXT_PUBLIC_APP_NAME="Chicken Dinner"
NEXT_PUBLIC_REOWN_APPKIT_PROJECT_ID=

# Polymarket read endpoints
POLYMARKET_GAMMA_API_BASE_URL="https://gamma-api.polymarket.com"
POLYMARKET_CLOB_API_BASE_URL="https://clob.polymarket.com"
POLYMARKET_DATA_API_BASE_URL="https://data-api.polymarket.com"
POLYMARKET_MARKET_CACHE_TTL_MS=60000

# Trading is fail-closed unless every gate below is explicitly configured.
POLYMARKET_PUBLIC_LIVE_ENABLED=false
POLYMARKET_DRY_RUN_ENABLED=false
POLYMARKET_BUILDER_CODE=
POLYMARKET_OPERATOR_CONFIRM_LIVE_TRADING=

# Server-only optional credentials. Never expose these as NEXT_PUBLIC_* values.
POLYMARKET_CLOB_API_KEY=
POLYMARKET_CLOB_API_SECRET=
POLYMARKET_CLOB_API_PASSPHRASE=

# Funding and collateral setup
POLYMARKET_OFFICIAL_FUNDING_URL="https://polymarket.com/portfolio"
POLYMARKET_COLLATERAL_SETUP_ENABLED=false
POLYGON_RPC_URL=
